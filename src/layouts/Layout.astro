---
import "../styles/global.css";

const frontmatter = Astro.props.frontmatter ?? {};
const title =
    frontmatter.title ?? Astro.props.title ?? "VR Building Simulation Research";
const pageTitle = title.replace(/\s*\|\s*VR Building Simulation Research$/, "");
const description =
    frontmatter.description ??
    Astro.props.description ??
    "Undergraduate research project exploring VR visualization environments for CAD-based building education and simulation.";
---

<!doctype html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width" />
        <meta name="description" content={description} />
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <link rel="icon" href="/favicon.ico" />
        <meta name="generator" content={Astro.generator} />
        <title>{title}</title>
    </head>
    <body>
        <header>
            <h1>{pageTitle}</h1>
            <ul aria-label="Primary pages">
                <li><a href="/">Home</a></li>
                <li><a href="/research/">Research</a></li>
                <li><a href="/team/">Team</a></li>
            </ul>
        </header>
        <main>
            <slot />
        </main>
    </body>
</html>
